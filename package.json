{
  "name": "infidao",
  "version": "0.1.0",
  "description": "InfiDao 六经注我 - Interactive Knowledge Graph Platform with AI-Powered Search",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --dir src --dir tests",
    "lint:fix": "next lint --fix --dir src --dir tests",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "download-model": "node scripts/download-model.js",
    "init-db": "node scripts/init-db.js",
    "import-data": "node scripts/import-data.js",
    "setup": "npm run download-model && npm run init-db && npm run import-data",
    "clean": "rm -rf .next dist node_modules/.cache",
    "analyze": "cross-env ANALYZE=true next build",
    "db:reset": "npm run clean && npm run init-db",
    "cache:clear": "node scripts/clear-cache.js",
    "health-check": "node scripts/health-check.js",
    "generate-search-artifacts": "node scripts/generate-search-artifacts.mjs",
    "smoke:release": "node scripts/release-smoke.mjs",
    "smoke:telemetry": "node scripts/annotation-telemetry-smoke.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.25.0",
    "@hookform/resolvers": "^3.9.1",
    "@lancedb/lancedb": "^0.5.2",
    "@next/bundle-analyzer": "^14.2.15",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@supabase/supabase-js": "^2.45.7",
    "@xenova/transformers": "^2.17.1",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.3.1",
    "framer-motion": "^11.11.17",
    "immer": "^10.1.1",
    "lucide-react": "^0.460.0",
    "next": "^14.2.15",
    "openai": "^4.71.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-hotkeys-hook": "^4.5.1",
    "react-use": "^17.5.1",
    "recharts": "^2.13.3",
    "redis": "^4.7.0",
    "sharp": "^0.33.5",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "vaul": "^1.1.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.16.13",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "critters": "^0.0.23",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.15",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "knowledge-graph",
    "ai-search",
    "chinese-classics",
    "interactive-learning",
    "nextjs",
    "typescript",
    "tailwindcss"
