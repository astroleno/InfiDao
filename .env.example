# InfiDao Environment Configuration
# Copy this file to .env.local and fill in your values

# ============= Database Configuration =============
# Path to LanceDB database
DATABASE_PATH=./data/lancedb

# Table names
EMBEDDINGS_TABLE=embeddings
PASSAGES_TABLE=passages

# ============= Model Configuration =============
# BGE-M3 Embedding Model
BGE_MODEL_PATH=./models/bge-m3
BGE_MODEL_REPO=BAAI/bge-m3

# ============= LLM Configuration =============
# Reboot annotation runtime supports:
# - fast: prefer secondary slot, then fallback to primary
# - quality: prefer primary slot, then fallback to secondary
# Default is fast.
ANNOTATION_LLM_MODE=fast
ANNOTATION_LLM_TIMEOUT_MS=6000
ANNOTATION_CACHE_TTL_MS=600000
ANNOTATION_CACHE_MAX_ENTRIES=100
ANNOTATION_TELEMETRY=on

# Reboot annotation runtime canonical model/base_url/api_key slots.
LLM_MODEL_PRIMARY=gpt-5.4-nano
LLM_BASE_URL_PRIMARY=https://api.openai.com/v1
LLM_API_KEY_PRIMARY=your_primary_api_key_here
LLM_MODEL_SECONDARY=gemini-3.1-flash-lite-preview
LLM_BASE_URL_SECONDARY=https://api.openai.com/v1
LLM_API_KEY_SECONDARY=your_secondary_api_key_here

# Backward-compatible aliases still work during migration, but runtime status
# reports them as legacy. Prefer the canonical slot variables above.
OPENAI_API_KEY=your_primary_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# GLM Configuration (Zhipu AI)
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Qwen Configuration (Alibaba Cloud)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============= Cache Configuration =============
# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============= Performance Configuration =============
# L1 Cache (in-memory)
L1_CACHE_SIZE=1000
L1_CACHE_TTL=60

# L2 Cache (Redis)
L2_CACHE_TTL=1800

# ============= Search Configuration =============
DEFAULT_TOP_K=5
DEFAULT_THRESHOLD=0.7
MAX_QUERY_LENGTH=500

# ============= Application Configuration =============
NODE_ENV=development
LOG_LEVEL=info
API_VERSION=v1
PORT=3000

# ============= Feature Flags =============
ENABLE_STREAMING=true
ENABLE_QUERY_EXPANSION=true
ENABLE_RERANKING=true
ENABLE_ANALYTICS=false

# ============= Development Only =============
# Enable debug logs
DEBUG=infidao:*

# Enable hot reload
NEXT_HMR_REFRESH=true
